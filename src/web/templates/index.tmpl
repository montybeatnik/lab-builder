{{ define "index_title" }}Lab Topology Studio{{ end }}

{{ define "index_content" }}
<header class="hero">
  <div>
    <p class="eyebrow">Arista Lab</p>
    <h1>Topology Studio</h1>
    <p class="subhead">Design a fabric, validate addressing, and get a ready-to-run plan for your lab.</p>
    <nav class="page-nav">
      <a href="/" class="active">Build</a>
      <a href="/viewer">Lab Viewer</a>
      <a href="/lab">Health</a>
    </nav>
  </div>
  <div class="status-card">
    <div class="status-line">
      <span id="buildStatus" class="status status-idle">Waiting for validation</span>
    </div>
    <div class="status-meta">
      <div>Base dir</div>
      <code id="baseDir">{{ .BaseDir }}</code>
    </div>
  </div>
</header>

<section class="grid">
  <div class="panel">
    <h2>Topology</h2>
    <p class="muted">Pick a topology, shape the node counts, and wire custom links when needed.</p>
    <div class="form-grid">
      <label>
        Topology
        <select id="topology">
          <option value="leaf-spine" selected>Leaf / Spine</option>
          <option value="full-mesh">Full Mesh</option>
          <option value="hub-spoke">Hub & Spoke</option>
          <option value="custom">Custom</option>
        </select>
      </label>
      <label>
        Node type
        <select id="nodeType">
          <option value="arista" selected>Arista cEOS</option>
          <option value="frr">FRR</option>
        </select>
      </label>
      <label data-topo="leaf-spine">
        Spines
        <input id="spines" type="number" min="1" max="64" value="2">
      </label>
      <label data-topo="leaf-spine">
        Leaves
        <input id="leaves" type="number" min="1" max="256" value="4">
      </label>
      <label data-topo="full-mesh">
        Nodes
        <input id="meshNodes" type="number" min="2" max="256" value="6">
      </label>
      <label data-topo="hub-spoke">
        Hubs
        <input id="hubs" type="number" min="1" max="16" value="1">
      </label>
      <label data-topo="hub-spoke">
        Spokes
        <input id="spokes" type="number" min="1" max="256" value="6">
      </label>
      <label data-topo="custom">
        Nodes
        <input id="customNodes" type="number" min="1" max="256" value="6">
      </label>
      <label>
        Edge nodes
        <input id="edgeNodes" type="number" min="0" max="512" value="8">
      </label>
      <label class="inline-check">
        Multi-homing
        <span class="checkline">
          <input id="multiHoming" type="checkbox">
          <span>Connect edge1 to two upstream leaf nodes</span>
        </span>
      </label>
    </div>

    <div id="customLinks" class="custom-links" data-topo="custom">
      <div class="links-header">
        <h3>Custom links</h3>
        <button id="addLinkBtn" class="ghost" type="button">Add link</button>
      </div>
      <div id="linkRows" class="link-rows"></div>
    </div>
  </div>

  <div class="panel graph-panel">
    <div class="graph-header">
      <h2>Graph preview</h2>
      <button id="refreshGraph" class="ghost" type="button">Refresh</button>
    </div>
    <div class="graph-wrap">
      <svg id="graph" viewBox="0 0 1000 520" role="img" aria-label="Topology graph preview"></svg>
    </div>
  <div class="legend">
      <div><span class="swatch spine"></span>Spine / Hub</div>
      <div><span class="swatch leaf"></span>Leaf / Spoke</div>
      <div><span class="swatch mesh"></span>Mesh / Custom</div>
      <div><span class="swatch edge"></span>Edge</div>
    </div>
  </div>
</section>

<section class="panel address-panel">
  <h2>Addressing</h2>
  <p class="muted">Provide a large infrastructure block; the system will divide it for loopbacks and point-to-point links.</p>
  <div class="form-grid">
    <label>
      Infrastructure CIDR
      <input id="infraCidr" type="text" placeholder="10.0.0.0/20" value="10.0.0.0/20">
    </label>
    <label>
      Edge CIDR
      <input id="edgeCidr" type="text" placeholder="172.16.0.0/24" value="172.16.0.0/24">
    </label>
  </div>
</section>

<section class="panel traffic-panel">
  <h2>Edge traffic profiles</h2>
  <p class="muted">Select the traffic types your edge clients will generate.</p>
  <div class="traffic-grid">
    <label class="traffic-card">
      <input type="checkbox" id="trafficVoice" checked>
      <div>
        <strong>Voice</strong>
        <p>UDP, steady 50 pps</p>
        <input type="range" id="levelVoice" min="1" max="5" value="3">
      </div>
    </label>
    <label class="traffic-card">
      <input type="checkbox" id="trafficVideo" checked>
      <div>
        <strong>Video</strong>
        <p>UDP, sustained throughput</p>
        <input type="range" id="levelVideo" min="1" max="5" value="4">
      </div>
    </label>
    <label class="traffic-card">
      <input type="checkbox" id="trafficEmail">
      <div>
        <strong>Email</strong>
        <p>TCP, bursty payloads</p>
        <input type="range" id="levelEmail" min="1" max="5" value="2">
      </div>
    </label>
    <label class="traffic-card">
      <input type="checkbox" id="trafficWeb" checked>
      <div>
        <strong>Web</strong>
        <p>TCP, frequent short flows</p>
        <input type="range" id="levelWeb" min="1" max="5" value="3">
      </div>
    </label>
  </div>
</section>

<section class="panel">
  <h2>Monitoring</h2>
  <p class="muted">Deploy Prometheus/Grafana plus SNMP and gNMI collectors inside the lab.</p>
  <div class="monitoring-grid">
    <label class="monitoring-card">
      <input type="checkbox" id="monSnmp" checked>
      <div>
        <strong>SNMP</strong>
        <p>Enable SNMP on EOS and scrape via snmp_exporter.</p>
      </div>
    </label>
    <label class="monitoring-card">
      <input type="checkbox" id="monGnmi" checked>
      <div>
        <strong>gNMI</strong>
        <p>Enable gNMI and collect metrics with gNMIc.</p>
      </div>
    </label>
  </div>
</section>

<section class="panel">
  <h2>Edge attachments</h2>
  <p class="muted">Choose where each edge node connects. Leave as auto to use round-robin.</p>
  <div id="edgeAttachments" class="edge-attachments"></div>
</section>

<section class="panel">
  <h2>Protocols</h2>
  <p class="muted">Drag protocols into role lanes to apply them to devices.</p>
  <div class="protocols">
    <div class="protocol-palette">
      <h3>Protocol palette</h3>
      <div class="protocol-chips" id="protocolPalette">
        <span class="protocol-chip" draggable="true" data-proto="bgp">BGP</span>
        <span class="protocol-chip" draggable="true" data-proto="evpn">EVPN</span>
        <span class="protocol-chip" draggable="true" data-proto="ospf">OSPF</span>
        <span class="protocol-chip" draggable="true" data-proto="isis">ISIS</span>
        <span class="protocol-chip" draggable="true" data-proto="vxlan">VXLAN</span>
        <span class="protocol-chip" draggable="true" data-proto="mpls-ldp">MPLS LDP</span>
        <span class="protocol-chip" draggable="true" data-proto="mpls-rsvp">MPLS RSVP</span>
      </div>
    </div>
    <div class="protocol-roles">
      <div class="protocol-lane" data-role="global">
        <div class="lane-header">
          <strong>Global</strong>
          <span class="muted">Applied to all nodes</span>
        </div>
        <div class="lane-drop" data-drop="global"></div>
      </div>
      <div class="protocol-lane" data-role="spine">
        <div class="lane-header">
          <strong>Spine / Hub</strong>
        </div>
        <div class="lane-drop" data-drop="spine"></div>
      </div>
      <div class="protocol-lane" data-role="leaf">
        <div class="lane-header">
          <strong>Leaf / Spoke</strong>
        </div>
        <div class="lane-drop" data-drop="leaf"></div>
      </div>
      <div class="protocol-lane" data-role="mesh">
        <div class="lane-header">
          <strong>Mesh / Custom</strong>
        </div>
        <div class="lane-drop" data-drop="mesh"></div>
      </div>
    </div>
  </div>
</section>

<section class="panel validate-panel">
  <div class="validate-header">
    <h2>Validation</h2>
    <div class="validate-actions">
      <button id="validateBtn" type="button">Validate &amp; Preview</button>
      <button id="buildBtn" class="ghost" type="button">Generate Lab</button>
      <button id="deployBtn" class="ghost" type="button">Deploy Lab</button>
      <button id="destroyBtn" class="ghost" type="button">Destroy Lab</button>
    </div>
  </div>
  <div class="form-grid">
    <label>
      Existing lab
      <select id="builderLabSelect">
        <option value="">Select a lab...</option>
      </select>
    </label>
    <label>
      Lab name
      <input id="labName" type="text" value="arista-lab">
    </label>
    <label>
      Overwrite existing
      <select id="forceBuild">
        <option value="false" selected>no</option>
        <option value="true">yes</option>
      </select>
    </label>
    <label>
      Use sudo for deploy
      <select id="deploySudo">
        <option value="true" selected>yes</option>
        <option value="false">no</option>
      </select>
    </label>
  </div>
  <div id="deployStatus" class="status-bar" hidden>
    <div class="status-bar-fill"></div>
    <div class="status-bar-text">Deploying...</div>
  </div>
  <div id="checks" class="checks"></div>
  <div id="buildResult" class="build-result" hidden></div>
  <div id="deployResult" class="build-result" hidden></div>
  <details class="plan">
    <summary>Generated plan</summary>
    <pre id="planJson"></pre>
  </details>
</section>

<section class="panel">
  <div class="validate-header">
    <h2>Config Preview</h2>
    <button id="renderConfigBtn" class="ghost" type="button">Render node config</button>
  </div>
  <p class="muted">Render a single node config from the current form state without generating the full lab.</p>
  <div class="form-grid">
    <label>
      Node
      <select id="configNode"></select>
    </label>
  </div>
  <div id="configPreviewMeta" class="muted"></div>
  <pre id="configPreview" class="result-block" hidden></pre>
  <pre id="daemonsPreview" class="result-block" hidden></pre>
</section>
{{ end }}
