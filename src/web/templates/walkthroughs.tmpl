{{ define "walkthroughs_title" }}Lab Walkthroughs{{ end }}

{{ define "walkthroughs_content" }}
<header class="hero">
  <div>
    <p class="eyebrow">LAB BUILDER</p>
    <h1>Lab Walkthroughs</h1>
    <p class="subhead">Choose a guided lab with predefined topology and base config, then step through validations as you build skills.</p>
    {{ template "primary_nav" . }}
  </div>
  <div class="status-card">
    <div class="status-line">
      <span id="walkthroughStatus" class="status status-idle">Select a walkthrough</span>
    </div>
    <div class="status-meta">
      <div>Base dir</div>
      <code>{{ .BaseDir }}</code>
    </div>
  </div>
</header>

<section class="panel">
  <h2>Walkthrough Catalog</h2>
  <p class="muted">Each lab boots with a small topology and enough base config for a focused learning outcome.</p>
  <div class="table-wrap">
    <table class="walkthrough-table">
      <thead>
        <tr>
          <th>Lab Name</th>
          <th>What You Will Learn</th>
          <th>Duration</th>
          <th>Status</th>
          <th></th>
        </tr>
      </thead>
      <tbody id="walkthroughRows">
        <tr><td colspan="5" class="muted">Loading walkthroughs...</td></tr>
      </tbody>
    </table>
  </div>
</section>

<section class="panel">
  <div class="validate-header">
    <h2>Launch</h2>
    <button id="walkthroughLaunchBtn" type="button">Deploy Selected Walkthrough</button>
  </div>
  <div class="form-grid">
    <label>
      Selected walkthrough
      <input id="walkthroughSelected" type="text" value="" readonly>
    </label>
    <label>
      Use sudo
      <select id="walkthroughUseSudo">
        <option value="true" selected>yes</option>
        <option value="false">no</option>
      </select>
    </label>
  </div>
  <pre id="walkthroughOutput" class="result-block" hidden></pre>
</section>

<section id="walkthroughRunner" class="grid" hidden>
  <div id="walkthroughWorkarea" class="walkthrough-workarea no-console">
    <div id="walkthroughTopologyPanel" class="panel graph-panel">
      <div class="graph-header">
        <h2>Walkthrough Topology</h2>
        <button id="walkthroughRefreshTopoBtn" class="ghost" type="button">Refresh</button>
      </div>
      <div class="graph-wrap future-wrap">
        <svg id="walkthroughGraph" class="future-mode" viewBox="0 0 1000 520" role="img" aria-label="Walkthrough topology"></svg>
      </div>
      <p class="muted">Click a node to open the command console for that node.</p>
    </div>
    <div id="walkthroughPaneResizer" class="walkthrough-pane-resizer" title="Drag to resize topology and console" aria-hidden="true"></div>
    <div id="walkthroughConsolePanel" class="panel" hidden>
      <div class="validate-header">
        <h2>Node Console</h2>
        <span id="walkthroughConsoleNode" class="muted">No node selected</span>
      </div>
      <p class="muted">Interactive shell session. Click terminal to focus, then type commands directly.</p>
      <div id="walkthroughTerminalScreen" class="walkthrough-terminal"></div>
      <div class="validate-actions">
        <button id="walkthroughConsoleReconnectBtn" class="ghost" type="button">Reconnect</button>
        <button id="walkthroughCaptureBtn" class="ghost" type="button">Capture Traffic</button>
      </div>
    </div>
  </div>
  <div id="walkthroughGuidePanel" class="panel walkthrough-guide-panel">
    <div class="validate-header">
      <h2>Step-by-Step Guide</h2>
      <button id="walkthroughPopoutGuideBtn" class="ghost" type="button">Pop Out Guide</button>
    </div>
    <ol id="walkthroughSteps" class="walkthrough-steps"></ol>
    <div class="validate-actions">
      <button id="walkthroughPrevStepBtn" class="ghost" type="button">Back</button>
      <button id="walkthroughNextStepBtn" type="button">Next</button>
    </div>
    <div id="walkthroughStepDetail" class="walkthrough-step-detail">
      <div id="walkthroughStepHeader" class="walkthrough-step-header"></div>
      <div id="walkthroughStepFacts" class="walkthrough-step-facts muted"></div>
      <div id="walkthroughStepCommands" class="walkthrough-step-commands"></div>
      <div id="walkthroughStepValidation" class="walkthrough-step-validation"></div>
    </div>
  </div>
</section>

<div id="walkthroughCaptureModal" class="capture-modal" hidden>
  <div class="capture-modal-card">
    <div class="validate-header">
      <h2>Live Capture Output</h2>
      <button id="walkthroughCaptureCloseBtn" class="ghost" type="button">Cancel</button>
    </div>
    <pre id="walkthroughCaptureOutput" class="result-block capture-output"></pre>
  </div>
</div>
{{ end }}
