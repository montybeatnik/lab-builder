{{ define "lab_title" }}Lab Health{{ end }}

{{ define "lab_content" }}
<header class="hero">
  <div>
    <p class="eyebrow">LAB BUILDER</p>
    <h1>Health Checks</h1>
    <p class="subhead">Run health checks and inspect node status for a deployed lab.</p>
    <nav class="page-nav">
      <a href="/">Build</a>
      <a href="/walkthroughs">Walkthroughs</a>
      <a href="/viewer">Lab Viewer</a>
      <a href="/live">Live Topology</a>
      <a href="/lab" class="active">Health</a>
    </nav>
  </div>
  <div class="status-card">
    <div class="status-line">
      <span id="labStatus" class="status status-idle">Ready for tests</span>
    </div>
    <div class="status-meta">
      <div>Base dir</div>
      <code id="baseDir">{{ .BaseDir }}</code>
    </div>
  </div>
</header>

<section class="panel">
  <h2>Lab target</h2>
  <p class="muted">Point the tests at a lab generated by the builder or any existing lab file.</p>
  <div class="form-grid">
    <label>
      Available labs
      <select id="labSelect">
        <option value="">Loading...</option>
      </select>
    </label>
    <label>
      Lab file
      <input id="labFile" type="text" value="">
    </label>
    <label>
      Timeout (seconds)
      <input id="labTimeout" type="number" min="5" max="120" value="20">
    </label>
    <label>
      Use sudo
      <select id="labSudo">
        <option value="true" selected>yes</option>
        <option value="false">no</option>
      </select>
    </label>
  </div>
</section>

<section class="grid">
  <div class="panel">
    <div class="validate-header">
      <h2>Inspect topology</h2>
      <button id="inspectBtn" type="button">Inspect</button>
    </div>
    <p class="muted">Returns the list of nodes, images, and addresses.</p>
    <pre id="inspectOut" class="result-block" hidden></pre>
  </div>
  <div class="panel">
    <div class="validate-header">
      <h2>EVPN health</h2>
      <button id="healthBtn" type="button">Run health</button>
    </div>
    <div class="form-grid">
      <label>
        Username
        <input id="healthUser" type="text" value="admin">
      </label>
      <label>
        Password
        <input id="healthPass" type="password" value="admin">
      </label>
    </div>
    <pre id="healthOut" class="result-block" hidden></pre>
  </div>
</section>

<section class="panel">
  <div class="validate-header">
    <h2>Running Node Config</h2>
    <button id="nodeConfigBtn" type="button">Load config</button>
  </div>
  <p class="muted">Load node names and config from the same selected lab used by inspect and health.</p>
  <div class="form-grid">
    <label>
      Node
      <select id="nodeConfigSelect">
        <option value="">Select a lab first</option>
      </select>
    </label>
  </div>
  <pre id="nodeConfigOut" class="result-block" hidden></pre>
  <pre id="nodeDaemonsOut" class="result-block" hidden></pre>
  <pre id="nodeStartupOut" class="result-block" hidden></pre>
</section>

<section class="panel">
  <h2>Next tests</h2>
  <p class="muted">Traffic profiles and performance checks will surface here as the lab grows.</p>
  <div class="check pass">
    <strong>Traffic profiles</strong>
    <span class="pill pass">READY</span>
    <p>Use the Deploy button to start the lab before launching traffic tests.</p>
  </div>
</section>
{{ end }}
